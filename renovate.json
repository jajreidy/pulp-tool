{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>konflux-ci/mintmaker-presets:cve-automerge-all",
    "group:recommended"
  ],
  "schedule": ["before 6am on Monday"],
  "tekton": {
    "schedule": ["before 6am on Monday"]
  },
  "updateNotScheduled": false,
  "prConcurrentLimit": 3,
  "prHourlyLimit": 1,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on Monday"]
  },
  "packageRules": [
    {
      "description": "Group pyproject.toml dependency bumps; Renovate regenerates uv.lock in the same PR",
      "matchManagers": ["pep621"],
      "groupName": "python pep621"
    },
    {
      "description": "Group uv.lock refresh (transitive pins) with pep621 updates",
      "matchManagers": ["pep621"],
      "matchUpdateTypes": ["lockFileMaintenance"],
      "groupName": "python pep621"
    }
  ]
}
